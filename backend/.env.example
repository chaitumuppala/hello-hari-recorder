# ASR engine: hybrid | faster_whisper | indic_conformer
# hybrid = IndicConformer for Indian languages + faster-whisper for English (recommended)
SCAM_ASR_ENGINE=hybrid

# Whisper model for English ASR (used by hybrid + faster_whisper engines)
# distil-small.en: 166M params, ~350MB RAM, 3.4% WER — optimal for CPU
SCAM_WHISPER_MODEL=distil-small.en

# Debug mode
SCAM_DEBUG=true
